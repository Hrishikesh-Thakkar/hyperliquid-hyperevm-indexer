# MongoDB connection URI
MONGO_URI=mongodb://localhost:27017/hl-indexer

# HyperEVM JSON-RPC endpoint (chain ID: 999 mainnet)
HYPEREVM_RPC_URL=https://hyperliquid.drpc.org

# Hyperliquid REST API base URL
HL_API_URL=https://api.hyperliquid.xyz/info

# Fastify API port
API_PORT=3000

# Comma-separated wallet addresses to index
WALLETS=0x30d83d444E230F652e2c62cb5697C8DaD503987b,0x4F0A01BAdAa24F762CeE620883f16C4460c06Be0,0xFaCC5b022641e9905bA3bac29b26E6d6191f2B8B,0x97e7d0c24d485aa07e8218528f8dfcd00ac63f75

# How often to poll Hyperliquid for new transactions (ms)
POLL_INTERVAL_MS=30000

# How often the matcher checks for unresolved transfers (ms)
MATCHER_INTERVAL_MS=30000

# Time window after an HL tx to search for its EVM counterpart (ms)
EVM_SEARCH_WINDOW_MS=600000

# Max retry attempts before marking a transfer as failed
MAX_RETRIES=5

# Base delay between matcher retries (ms). Actual delay uses exponential
# backoff: RETRY_DELAY_MS * 2^retryCount, capped at 30 minutes.
RETRY_DELAY_MS=120000

# Log level for the Fastify/pino logger (trace|debug|info|warn|error|fatal)
LOG_LEVEL=info
